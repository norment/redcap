# ENV shared across containers

# Prefix for multiple instances
PREFIX=redcap_

# Container image tag (must match the GHCR bundle)
IMAGE_TAG=latest

# MySQL
MYSQL_DATABASE=redcap
MYSQL_ROOT_PASSWORD=redcap
MYSQL_REDCAP_USER=redcap_user

# phpmyadmin
PHPMYADMIN_PORT=9000

# REDCap
REDCAP_PORT=8000
REDCAP_SALT=qwertyui

# GitHub Container Registry credentials for pulling the segmentation image.
# GHCR_LOGIN is the PAT with read:packages scope.
GHCR_USERNAME=
GHCR_LOGIN=

